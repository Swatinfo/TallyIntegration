# Modules/Tally/scripts/.smoke.env.example
# Copy to Modules/Tally/scripts/.smoke.env and edit. This file is gitignored.
#
# All keys below are OPTIONAL — the script works with pure defaults.
# Set only what you need to override.

# -----------------------------------------------------------------------------
# Laravel side
# -----------------------------------------------------------------------------
# Base URL of your running Laravel app (no trailing slash).
# Default: https://tallyintegration.test (Herd/Valet-style .test domain).
# For `php artisan serve`, use http://127.0.0.1:8000 instead.
# LARAVEL_BASE_URL=https://tallyintegration.test

# Pass -k to curl if your local .test domain uses a self-signed cert curl
# doesn't trust. Usually only needed on some Herd/Valet installs on Windows.
# CURL_INSECURE=1

# If you already have a Sanctum token, set it here to skip auth bootstrap.
# The script will still pass --no-bootstrap implicitly when this is set.
# TALLY_API_TOKEN=1|abcdef...

# -----------------------------------------------------------------------------
# Smoke-test user (only used when bootstrap runs)
# -----------------------------------------------------------------------------
# SMOKE_USER_EMAIL=smoke-test@local
# SMOKE_USER_NAME=Smoke Test

# -----------------------------------------------------------------------------
# Tally side (matches the connection row we create)
# -----------------------------------------------------------------------------
# TALLY_HOST=localhost
# TALLY_PORT=9000

# Target Tally company (default: "SwatTech Demo").
# IMPORTANT: This company must be CREATED and LOADED in TallyPrime before running the script.
# The script's preflight aborts if the target company isn't loaded — no data is ever
# written to any other company.
# TALLY_COMPANY="SwatTech Demo"

# Short code used in /api/tally/{CONN_CODE}/... routes.
# CONN_CODE=DEMO
# CONN_NAME="Demo HQ"

# -----------------------------------------------------------------------------
# Data conventions
# -----------------------------------------------------------------------------
# Prefix used on every created entity's name. Cleanup only deletes names with this prefix.
# DEMO_PREFIX=-DEMO-

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Override the log directory (default: <project>/storage/logs/tally).
# LOG_DIR=/var/log/tally-smoke
